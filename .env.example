# ============================
# 青岛万翔辉日文官网 环境变量模板
# 复制为 .env.local 后填值（.env.local 不提交）
# ============================

# 站点
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_DEFAULT_LOCALE=ja

# 邮件 (Resend)
RESEND_API_KEY=re_XXXXXX
INQUIRY_NOTIFY_EMAIL=sales@example.com

# 防爬 (reCAPTCHA v3)
RECAPTCHA_SECRET_KEY=XXXXXX
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=XXXXXX

# CMS (二选一，待客户确认 → XXX-CMS)
# SANITY_PROJECT_ID=
# SANITY_DATASET=production
# SANITY_API_TOKEN=
# STRAPI_URL=
# STRAPI_API_TOKEN=

# 分析（GA4 / GTM）
# 留空则不加载任何分析脚本；填值后仍需访客在同意横幅点「同意」才会加载（APPI/GDPR）
NEXT_PUBLIC_GA_ID=
NEXT_PUBLIC_GTM_ID=
